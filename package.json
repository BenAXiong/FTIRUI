{
  "name": "mlirui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "playwright test",
    "test:a11y": "playwright test -c playwright.a11y.config.js",
    "lint:js": "eslint --ext .js,.jsx,.mjs apps/ftirui/ft/static/ft/js",
    "format": "prettier --write apps/ftirui/ft/static/ft/js",
    "check:django": "python apps/ftirui/manage.py check"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.3",
    "@playwright/test": "^1.56.1",
    "jsdom": "^24.1.0",
    "vitest": "^1.6.0"
  }
}
