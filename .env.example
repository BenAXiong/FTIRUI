# Django core
DJANGO_SETTINGS_MODULE=ftirui.settings
SECRET_KEY=change-me
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,scix-ui1e.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://scix-ui1e.onrender.com

# Database
# Leave DATABASE_URL empty to use the local SQLite fallback.
# For docker-compose/local Postgres:
DATABASE_URL=postgres://ftirui:ftirui@db:5432/ftirui
DB_CONN_MAX_AGE=60

# Social auth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Product analytics (optional)
POSTHOG_ENABLED=false
POSTHOG_PUBLIC_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Lemon Squeezy billing (optional)
LEMONSQUEEZY_ENABLED=false
LEMONSQUEEZY_MODE=test
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_STORE_DOMAIN=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=
LEMONSQUEEZY_CHECKOUT_SUCCESS_URL=
LEMONSQUEEZY_CHECKOUT_CANCEL_URL=

# Smoke/Playwright defaults
SMOKE_BASE_URL=http://localhost:8000
SMOKE_USERNAME=admin@example.com
SMOKE_PASSWORD=changeme

# UI feature flags
WORKSPACE_LEGACY_ENABLED=true
WORKSPACE_DEV_SHORTCUT_ENABLED=true
DASHBOARD_V2_ENABLED=true
SERVE_MEDIA_FILES=true
MEDIA_STORAGE_TRANSIENT=true

# Misc
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
